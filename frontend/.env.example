# Required for maps (ShipmentMap); optional but recommended for full UI
VITE_MAPBOX_TOKEN=

# Algorand JSON-RPC / indexer (browser reads chain metadata)
VITE_ALGORAND_NODE=https://testnet-api.algonode.cloud
VITE_INDEXER_URL=https://testnet-idx.algonode.cloud

# Deployed app id (testnet). Must match backend APP_ID for wallet flows.
VITE_APP_ID=758734899

# FastAPI base URL.
# Local dev: leave unset and use Vite proxy — the app calls same-origin `/api` and vite.config proxies to this URL:
VITE_API_URL=http://127.0.0.1:8000
#
# Production on Vercel (required for a reliable dashboard): set VITE_API_URL to your deployed FastAPI root, e.g.
#   VITE_API_URL=https://your-api.onrender.com
# Add your Vercel domain to the API CORS list (see app.py _CORS_ORIGINS / CORS_EXTRA_ORIGINS).
# If unset, the build falls back to a public demo URL that may be offline on free tiers.

# Optional: landing page “live proof” card uses this shipment; if unset, first ID from GET /config or /shipments is used
# VITE_LANDING_DEMO_SHIPMENT_ID=

# Optional: ElevenLabs embedded conversational widget / public agent id only (never API keys in Vite)
# VITE_ELEVENLABS_AGENT_ID=
