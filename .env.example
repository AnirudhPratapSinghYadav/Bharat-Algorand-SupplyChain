# Copy to `.env` — never put real secrets in this file; commit only placeholders.
#
# Backend / server only (no VITE_ prefix here). For the Vite app, use `frontend/.env.example` → `frontend/.env`.

# Required for AI features (run-jury, NaviBot, etc.)
GEMINI_API_KEY=

# Oracle / deployer — Algorand uses a 25-word mnemonic. Generate: python generate_oracle.py
# verify_oracle_setup() runs at server startup (skipped under pytest).
DEPLOYER_MNEMONIC=
ORACLE_MNEMONIC=
# Optional: separate escrow for oracle stakes (defaults to oracle address)
ORACLE_STAKE_ESCROW_ADDRESS=

APP_ID=0
ALGO_NETWORK=testnet

ALGOD_ADDRESS=https://testnet-api.algonode.cloud
RSS_LOGISTICS_URL=https://shippingwatch.com/service/rss
N8N_WEBHOOK_URL=

CORS_EXTRA_ORIGINS=
NAVIBOT_RL_PER_MIN=24

ELEVENLABS_API_KEY=
# Voice id from ElevenLabs dashboard (e.g. name or id string), not the API key.
ELEVENLABS_VOICE_ID=
ELEVENLABS_WEBHOOK_SECRET=

# Frontend (Vite): use frontend/.env.example → frontend/.env (VITE_* only there).
