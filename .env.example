# Pramanik — copy to `.env` in repo root (never commit `.env`)

# ═══════════════════════════════════════════════════════════════════════
# WHAT TO FUND (TestNet ALGO)
# ═══════════════════════════════════════════════════════════════════════
# Fund the ORACLE wallet — same 25-word account as ORACLE_MNEMONIC below.
# This account registers shipments, runs the jury on-chain, and pays txn fees.
#
#   Faucet: https://bank.testnet.algorand.network/
#   Paste ORACLE_ADDRESS (58-char public address) — NOT the 25-word mnemonic
#   Derive: python -c "from algosdk import mnemonic; from algosdk.account import address_from_private_key; print(address_from_private_key(mnemonic.to_private_key('word1 ... word25')))"
# ORACLE_ADDRESS=GUZQLWNOWGTREQ6TNV6BOWZAI65EL64CVMBO47UBXSIDDZ3EVZV35FQOQM
# CONTRACT_APP_ADDRESS=   # from APP_ID — algosdk.logic.get_application_address(APP_ID)
# LORA_APP_URL=https://lora.algokit.io/testnet/application/759052600
#
# Recommended balances:
#   • Minimum to start API:     ~2 ALGO  (SEED_MIN_ORACLE_MICRO=2000000)
#   • Comfortable for demo:     ~5–10 ALGO (seed 3 lanes + jury + settle)
#   • Contract app account:     ~0.5 ALGO (auto-funded on deploy)
#
# Buyers fund escrow separately via Pera Wallet when they click "Lock escrow"
# on the dashboard — that uses the connected wallet, not the oracle.

# ═══════════════════════════════════════════════════════════════════════
# REQUIRED
# ═══════════════════════════════════════════════════════════════════════

# Oracle wallet (25 words) — creator of the deployed app on TestNet
ORACLE_MNEMONIC=word1 word2 word3 ... word25

# Deployed application ID (from `python scripts/full_deploy.py` or Lora URL)
APP_ID=759052600

# Google Gemini — AI jury (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# ═══════════════════════════════════════════════════════════════════════
# NETWORK (defaults in config.json — override here if needed)
# ═══════════════════════════════════════════════════════════════════════
ALGO_NETWORK=testnet
ALGOD_ADDRESS=https://testnet-api.algonode.cloud
INDEXER_URL=https://testnet-idx.algonode.cloud
LORA_BASE_URL=https://lora.algokit.io/testnet

# ═══════════════════════════════════════════════════════════════════════
# SEEDING & AUTO-JURY
# ═══════════════════════════════════════════════════════════════════════
AUTO_SEED_DEMO=0
SEED_MIN_ORACLE_MICRO=2000000
AUTO_JURY_ENABLED=0
AUTO_JURY_INTERVAL_MINUTES=60
AUTO_JURY_MIN_HOURS_SINCE_LAST=6
AUTO_SETTLE=0

# ═══════════════════════════════════════════════════════════════════════
# TELEGRAM (optional — verdict / register / settlement alerts)
# ═══════════════════════════════════════════════════════════════════════
# Token format: 123456789:AAH...  (not @botname:...)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_IDS=6114934908

# ═══════════════════════════════════════════════════════════════════════
# ELEVENLABS (optional — Pramanik Bot voice at /pramanik-bot)
# ═══════════════════════════════════════════════════════════════════════
# ELEVENLABS_API_KEY=
# ELEVENLABS_AGENT_ID=agent_xxxxxxxx

# ═══════════════════════════════════════════════════════════════════════
# DEPLOY & HOSTING (Render API + Vercel frontend)
# See HOSTING.md for step-by-step instructions.
# ═══════════════════════════════════════════════════════════════════════
# DEPLOYER_MNEMONIC=   # only for `full_deploy.py` if different from oracle
#
# After Vercel deploy, set your exact frontend URL (no trailing slash):
# CORS_EXTRA_ORIGINS=https://your-app.vercel.app
# VERIFY_PUBLIC_BASE_URL=https://your-app.vercel.app
#
# OFFCHAIN_EVENTS=1
# SKIP_ORACLE_VERIFY=0
