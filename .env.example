# Copy to `.env` — never put real secrets in this file; commit only placeholders.
#
# Backend / server only (no VITE_ prefix here). For the Vite app, use `frontend/.env.example` → `frontend/.env`.
#
# Terminal-first secrets (recommended): export vars in the same shell before `python app.py` / uvicorn.
# They override missing keys from `.env` and are not overwritten by empty lines in `.env`
# (app uses load_dotenv() with override=False).
#
# PowerShell (single line — replace ... with your 25 words and API key):
#   $env:GEMINI_API_KEY="..."; $env:ORACLE_MNEMONIC="word1 ... word25"; $env:APP_ID="758734899"; python -m uvicorn app:app --host 127.0.0.1 --port 8000
#
# Optional: OpenAI fallback if Gemini JSON parsing fails (jury still has deterministic fallbacks).
# OPENAI_API_KEY=

# Required for AI features (run-jury, NaviBot, etc.)
GEMINI_API_KEY=
# Optional: comma-separated model ids tried in order (default: gemini-2.5-flash,…,gemini-1.5-flash)
# GEMINI_MODEL_CHAIN=gemini-2.5-flash,gemini-2.0-flash,gemini-1.5-flash-8b,gemini-1.5-flash

# Oracle / deployer — Algorand uses a 25-word mnemonic (fund on TestNet from the faucet).
# verify_oracle_setup() runs at server startup (skipped under pytest).
# Local UI-only: set SKIP_ORACLE_VERIFY=1 to start the API without a valid 25-word mnemonic (not for production).
# SKIP_ORACLE_VERIFY=
DEPLOYER_MNEMONIC=
ORACLE_MNEMONIC=
# Optional: separate escrow for oracle stakes (defaults to oracle address)
ORACLE_STAKE_ESCROW_ADDRESS=

# After `algokit project deploy testnet`, set APP_ID to the new application id (keep in sync with frontend VITE_APP_ID).
APP_ID=759018740
ALGO_NETWORK=testnet

ALGOD_ADDRESS=https://testnet-api.algonode.cloud
RSS_LOGISTICS_URL=https://shippingwatch.com/service/rss
N8N_WEBHOOK_URL=

CORS_EXTRA_ORIGINS=
# Optional: CoinGecko Pro/demo key (sent as x-cg-demo-api-key); free tier works without it.
# COINGECKO_API_KEY=
# Optional: base URL embedded in Supplier Passport ASA metadata (defaults to Vercel demo URL).
# PASSPORT_URL_BASE=https://pramanik.vercel.app

# Optional: POST /admin/pause and /admin/unpause (body: {"admin_secret": "..."}).
# ADMIN_SECRET=

# Optional: load offchain_events.json into Navibot logistics context (default: off — jury uses chain + weather + Gemini only).
# OFFCHAIN_EVENTS=

NAVIBOT_RL_PER_MIN=24

ELEVENLABS_API_KEY=
# Voice id from ElevenLabs dashboard (e.g. name or id string), not the API key.
ELEVENLABS_VOICE_ID=
ELEVENLABS_WEBHOOK_SECRET=

# Frontend (Vite): use frontend/.env.example → frontend/.env (VITE_* only there).
