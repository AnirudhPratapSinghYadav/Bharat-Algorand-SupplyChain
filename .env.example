# Pramanik — Environment Variables
# Copy to .env and fill in values. NEVER commit .env.

# ── Algorand ─────────────────────────────────────────────────────────
# REQUIRED: The oracle account mnemonic (25 words).
# This account must be the creator of the deployed NaviTrust contract.
# Testnet faucet: https://bank.testnet.algorand.network/
ORACLE_MNEMONIC=word1 word2 word3 ... word25

# REQUIRED: APP_ID of the deployed NaviTrust contract (set after algokit deploy).
APP_ID=

# OPTIONAL: Network selection (testnet | mainnet | localnet)
ALGO_NETWORK=testnet

# ── AI ───────────────────────────────────────────────────────────────
# REQUIRED for AI jury: Google Gemini API key
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OPTIONAL: Override Gemini model chain (comma-separated)
# GEMINI_MODEL_CHAIN=gemini-2.5-pro,gemini-2.5-flash,gemini-1.5-flash-8b

# ── Backend Config ───────────────────────────────────────────────────
# OPTIONAL: Extra CORS origins (comma-separated)
# CORS_EXTRA_ORIGINS=https://yourapp.vercel.app

# OPTIONAL: Skip oracle verification on startup (read-only deploys)
# SKIP_ORACLE_VERIFY=0

# OPTIONAL: Automatically seed demo shipments on startup
AUTO_SEED_DEMO=1

# Minimum oracle balance in microAlgo before auto-seed / seed_blockchain.py (default 2_000_000 ≈ 2 ALGO for dev)
SEED_MIN_ORACLE_MICRO=2000000

# OPTIONAL: Auto-settle when arbiter returns SETTLE verdict
# AUTO_SETTLE=0

# OPTIONAL: Load offchain_events.json into agent logistics context
# OFFCHAIN_EVENTS=1

# OPTIONAL: CoinGecko API key (higher rate limits)
# COINGECKO_API_KEY=

# OPTIONAL: Public verify page base for ARC-69 / passport deep links (no trailing slash)
# VERIFY_PUBLIC_BASE_URL=https://pramanik.vercel.app

# Certificate ASA `url` field: edit `smart_contracts/navi_trust/contract.py` (settle_shipment itxn) before `algokit project run build` if your public verify base is not pramanik.vercel.app (max 96 bytes).
EVENT_POLL_INTERVAL_SECONDS=10
AUTO_JURY_ENABLED=0
AUTO_JURY_INTERVAL_MINUTES=30
AUTO_JURY_MIN_HOURS_SINCE_LAST=6
AUTO_JURY_INTERVAL_SECONDS=1800
AUTO_SETTLE=0

# Telegram alerts (optional — verdict, settlement, auto-jury summary)
# BotFather token only: 123456789:AAH... (not @botname:...)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_IDS=123456789

# ElevenLabs ConvAI voice agent (public agent id) + TTS for Pramanik Bot audio_url
# ELEVENLABS_API_KEY=
# ELEVENLABS_AGENT_ID=agent_xxxxxxxx
# ELEVENLABS_VOICE_ID=

# CORS: add your Vercel frontend origin (comma-separated)
# CORS_EXTRA_ORIGINS=https://your-app.vercel.app
# WebSocket /ws/live poll (seconds); optional override of config.json websocket_poll_seconds
# WEBSOCKET_POLL_SECONDS=2

# DEPLOYER_MNEMONIC is only needed during contract deployment (algokit deploy).
# DEPLOYER_MNEMONIC=word1 word2 ...
